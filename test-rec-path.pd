#N canvas 80 80 900 700 12;
#X text 20 10 TEST REC-PATH STITCH -- fase 1 niveau B;
#X text 20 30 Doel: bewijs dat een pad-symbol uit een receive in een dynamische;
#X text 20 50 soundfiler-write-msg gestitched kan worden;
#X text 20 70 INSTRUCTIES:;
#X text 20 90 1) Klik msg 'set path' om het pad te zetten;
#X text 20 110 2) Klik bng 'fill_array' om 1s sinus te schrijven (DSP MOET AAN);
#X text 20 130 3) Klik bng 'WRITE' om soundfiler te triggeren;
#X text 20 150 4) Verifieer in terminal: ls -la /tmp/test-rec-path.wav;
#X text 20 200 -- pad-receiver-keten --;
#X msg 20 230 \; test-rec-path-in /tmp/test-rec-path.wav;
#X obj 20 270 r test-rec-path-in;
#X obj 20 295 symbol;
#X obj 20 320 s test-rec-path-sym;
#X obj 200 270 r test-rec-path-sym;
#X obj 200 295 print path-now;
#X text 20 360 -- audio-bron: continue sinus naar tabwrite~ --;
#X obj 400 200 bng 20 250 50 0 empty empty fill_array 17 7 0 10 -262144 -1 -1;
#X obj 400 260 osc~ 440;
#X obj 400 285 *~ 0.5;
#X obj 400 310 tabwrite~ test-array;
#N canvas 0 0 450 250 (subpatch) 0;
#X array test-array 48000 float 2;
#X coords 0 1 48000 -1 200 100 1 0 0;
#X restore 550 200 graph;
#X text 20 460 -- write-keten met dynamische pad-stitch --;
#X obj 20 490 bng 30 250 50 0 empty empty WRITE 17 7 0 12 -260818 -1 -1;
#X obj 20 535 t b b;
#X msg 20 565 48000;
#X obj 20 590 list prepend write -nframes;
#X obj 20 615 list append -wave;
#X obj 200 565 r test-rec-path-sym;
#X obj 20 640 list append;
#X obj 20 665 list append test-array;
#X obj 20 690 list trim;
#X obj 20 720 t a a;
#X obj 200 745 print soundfiler-cmd;
#X obj 20 770 soundfiler;
#X connect 10 0 11 0;
#X connect 11 0 12 0;
#X connect 13 0 14 0;
#X connect 16 0 19 0;
#X connect 17 0 18 0;
#X connect 18 0 19 0;
#X connect 22 0 23 0;
#X connect 23 0 24 0;
#X connect 24 0 25 0;
#X connect 25 0 26 0;
#X connect 26 0 28 0;
#X connect 27 0 28 1;
#X connect 28 0 29 0;
#X connect 29 0 30 0;
#X connect 30 0 31 0;
#X connect 31 0 33 0;
#X connect 31 1 32 0;
